{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    // Bundler mode
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Linting
    "baseUrl": "./",
    "paths": {
      "@/web/*": ["./src/*"]
    }
  }
}
